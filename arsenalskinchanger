    UI.ScrollUp.Size = Vector2.new(scrollW, btnSize)
    UI.ScrollDown.Position = Vector2.new(scrollX, scrollY + scrollH - btnSize)
    UI.ScrollDown.Size = Vector2.new(scrollW, btnSize)
    UI.ScrollTrack.Position = Vector2.new(scrollX, scrollY + btnSize)
    UI.ScrollTrack.Size = Vector2.new(scrollW, scrollH - btnSize * 2)

    local totalItems = #tab.filtered
    local maxScroll = math.max(0, totalItems - CFG.List.MaxVisible)
    local trackH = UI.ScrollTrack.Size.Y
    local thumbRatio = math.min(1, CFG.List.MaxVisible / math.max(1, totalItems))
    local thumbH = math.max(8, trackH * thumbRatio)
    tab.smooth = tab.smooth + (tab.scroll - tab.smooth) * 0.25
    local scrollRatio = 0
    if maxScroll > 0 then scrollRatio = tab.smooth / maxScroll end
    UI.ScrollThumb.Position = Vector2.new(scrollX + 1, UI.ScrollTrack.Position.Y + (scrollRatio * (trackH - thumbH)))
    UI.ScrollThumb.Size = Vector2.new(scrollW - 2, thumbH)

    local currentSelected = State[tab.stateKey]
    for i = 1, CFG.List.MaxVisible do
        local index = tab.scroll + i
        local name = tab.filtered[index]
        local itemUI = UI.Items[i]
        if name then
            itemUI.Text.Visible = true
            itemUI.Highlight.Visible = true
            local rowY = listPos.Y + 2 + ((i - 1) * CFG.List.ItemHeight)
            local rowX = listPos.X + 2
            itemUI.Highlight.Position = Vector2.new(rowX, rowY)
            itemUI.Highlight.Size = Vector2.new(listW - scrollW - 6, CFG.List.ItemHeight)
            itemUI.Text.Position = Vector2.new(rowX + 4, rowY + 2)
            itemUI.Text.Text = (State.ActiveTab == 1 and State.Favorites[name] and "* " or "") .. name
            if name == currentSelected then
                itemUI.Text.Color = CFG.Colors.Accent
                itemUI.Highlight.Color = Color3.fromRGB(35, 35, 35)
            elseif isMouseOver(itemUI.Highlight.Position, itemUI.Highlight.Size) then
                itemUI.Highlight.Color = Color3.fromRGB(30, 30, 30)
                itemUI.Text.Color = CFG.Colors.Text
            else
                itemUI.Text.Color = CFG.Colors.Text
                itemUI.Highlight.Color = CFG.Colors.BgDark
            end
        else
            itemUI.Text.Visible = false
            itemUI.Highlight.Visible = false
        end
    end

    UI.RGroupBox.Position = rgPos
    UI.RGroupBox.Size = Vector2.new(rgW, cH)
    UI.RGroupTitleBg.Position = rgPos + Vector2.new(10, -2)
    UI.RGroupTitleBg.Size = Vector2.new(55, 6)
    UI.RGroupTitle.Position = rgPos + Vector2.new(15, -8)

    local ry = rgPos.Y + 14
    local rx = rgPos.X + 10
    local boxSz = 10

    if State.ActiveTab == 1 then
        UI.FixBoxOutline.Visible = true
        UI.FixText.Visible = true
        UI.FixBoxOutline.Position = Vector2.new(rx, ry)
        UI.FixBoxOutline.Size = Vector2.new(boxSz, boxSz)
        if State.SwingFixEnabled then
            UI.FixBoxFill.Visible = true
            UI.FixBoxFill.Position = Vector2.new(rx + 2, ry + 2)
            UI.FixBoxFill.Size = Vector2.new(boxSz - 4, boxSz - 4)
            UI.FixText.Color = CFG.Colors.Text
        else
            UI.FixBoxFill.Visible = false
            UI.FixText.Color = CFG.Colors.TextDim
        end
        UI.FixText.Position = Vector2.new(rx + boxSz + 6, ry - 1)
        ry = ry + 26
    else
        UI.FixBoxOutline.Visible = false
        UI.FixBoxFill.Visible = false
        UI.FixText.Visible = false
    end

    UI.PreviewLabel.Position = Vector2.new(rx, ry)
    ry = ry + 14
    UI.PreviewName.Position = Vector2.new(rx, ry)
    UI.PreviewName.Text = State[tab.stateKey] or "None"
    ry = ry + 22

    local rBtnW = rgW - 20
    UI.RandomBtn.Position = Vector2.new(rx, ry)
    UI.RandomBtn.Size = Vector2.new(rBtnW, 20)
    UI.RandomBorder.Position = UI.RandomBtn.Position
    UI.RandomBorder.Size = UI.RandomBtn.Size
    UI.RandomText.Position = Vector2.new(rx + rBtnW / 2, ry + 3)
    UI.RandomBtn.Color = isMouseOver(UI.RandomBtn.Position, UI.RandomBtn.Size) and Color3.fromRGB(30, 30, 30) or CFG.Colors.BgDark
    ry = ry + 30

    UI.KeybindLabel.Position = Vector2.new(rx, ry)
    ry = ry + 15
    local kbW = rgW - 20
    UI.KeybindBtn.Position = Vector2.new(rx, ry)
    UI.KeybindBtn.Size = Vector2.new(kbW, 18)
    UI.KeybindBorder.Position = UI.KeybindBtn.Position
    UI.KeybindBorder.Size = UI.KeybindBtn.Size
    UI.KeybindText.Position = Vector2.new(rx + kbW / 2, ry + 2)
    if State.RebindMode then
        UI.KeybindText.Text = "..."
        UI.KeybindBorder.Color = CFG.Colors.Accent
    else
        UI.KeybindText.Text = GetKeyName(State.ToggleKey)
        UI.KeybindBorder.Color = CFG.Colors.Border1
    end
    ry = ry + 28

    local csSize = 12
    local csGap = 3
    for ci = 1, #UI.ColorSquares do
        local sq = UI.ColorSquares[ci]
        local sx = rx + (ci - 1) * (csSize + csGap)
        sq.Fill.Position = Vector2.new(sx, ry)
        sq.Fill.Size = Vector2.new(csSize, csSize)
        sq.Border.Position = Vector2.new(sx, ry)
        sq.Border.Size = Vector2.new(csSize, csSize)
        sq.Border.Color = (ci == State.AccentIndex) and CFG.Colors.Text or CFG.Colors.Border2
    end

    if State.AnimProgress < 1 then
        State.AnimProgress = math.min(1, State.AnimProgress + 0.1)
    end
    for _, obj in ipairs(UIObjects) do
        pcall(function() obj.Transparency = State.AnimProgress end)
    end
end

local function cleanup()
    for _, o in ipairs(UIObjects) do pcall(function() o:Remove() end) end
end

