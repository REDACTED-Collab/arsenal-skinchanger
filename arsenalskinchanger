local function isMouseOver(pos, size)
    if not mouse or not State.MenuOpen then return false end
    local m = Vector2.new(mouse.X, mouse.Y)
    return m.X >= pos.X and m.X <= pos.X + size.X and m.Y >= pos.Y and m.Y <= pos.Y + size.Y
end

local function setMenuVisible(visible)
    State.MenuOpen = visible
    if visible then State.AnimProgress = 0 end
    for _, obj in ipairs(UIObjects) do
        obj.Visible = visible
    end
    if visible and not State.SwingFixEnabled then
        UI.FixBoxFill.Visible = false
    end
    for _, h in ipairs(HudObjects) do
        h.Visible = not visible
    end
end

local function updateFilter()
    local tab = getTab()
    local favs, rest = {}, {}
    for _, name in ipairs(tab.allItems) do
        local match = (tab.search == "") or string.find(string.lower(name), string.lower(tab.search))
        if match then
            if State.ActiveTab == 1 and State.Favorites[name] then
                table.insert(favs, name)
            else
                table.insert(rest, name)
            end
        end
    end
    local merged = {}
    for _, n in ipairs(favs) do table.insert(merged, n) end
    for _, n in ipairs(rest) do table.insert(merged, n) end
    tab.filtered = merged
    tab.scroll = 0
end

local function handleTyping()
    if not State.SearchFocused or not State.MenuOpen or not isrbxactive() then
        State.LastKeys = {}
        return
    end
    
    local tab = getTab()
    local changed = false
    local lk = State.LastKeys
    
    local bksp = iskeypressed(0x08)
    if bksp and not lk[0x08] and #tab.search > 0 then
        tab.search = string.sub(tab.search, 1, -2)
        changed = true
    end
    lk[0x08] = bksp
    
    local spc = iskeypressed(0x20)
    if spc and not lk[0x20] then
        tab.search = tab.search .. " "
        changed = true
    end
    lk[0x20] = spc
    
    for k = 0x41, 0x5A do
        local down = iskeypressed(k)
        if down and not lk[k] then
            local char = string.char(k)
            if not iskeypressed(0x10) then char = string.lower(char) end
            tab.search = tab.search .. char
            changed = true
        end
        lk[k] = down
    end
    for k = 0x30, 0x39 do
        local down = iskeypressed(k)
        if down and not lk[k] then
            tab.search = tab.search .. string.char(k)
            changed = true
        end
        lk[k] = down
    end
    
    if changed then
        updateFilter()
    end
end

